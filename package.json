{
  "name": "imaxnearme.com",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "preview:cf": "npm run build && wrangler dev",
    "fetch-venues": "bash scripts/fetch-imax-venues.sh",
    "upload-venues": "bash scripts/safe-r2-upload.sh imaxnearme-data/imax-venues.json imax-venues.json",
    "upload-cache": "bash scripts/safe-r2-upload.sh imaxnearme-data/theatre-details.json theatre-details.json",
    "download-cache": "wrangler r2 object get imaxnearme-data/theatre-details.json --file=theatre-details.json --remote",
    "upload-imax-cache": "bash scripts/safe-r2-upload.sh imaxnearme-data/imax-urls.json imax-urls.json",
    "download-imax-cache": "wrangler r2 object get imaxnearme-data/imax-urls.json --file=imax-urls.json --remote"
  },
  "dependencies": {
    "@types/supercluster": "^7.1.3",
    "maplibre-gl": "^5.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-map-gl": "^8.1.0",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wrangler": "^4.69.0"
  }
}
